# --- Server ---
PORT=8080

# --- PostgreSQL (Supabase Session Mode Pooler) ---
DATABASE_URL="postgres://postgres.[PROJECT_ID]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# --- Redis (Upstash with TLS) ---
REDIS_URL="rediss://default:[TOKEN]@[ENDPOINT].upstash.io:6379"

# --- GeoIP (MaxMind GeoLite2-City) ---
GEOIP_DB_PATH="data/GeoLite2-City.mmdb"

# --- Admin Authentication ---
# Generate with: echo -n "your-admin-password" | sha256sum
ADMIN_SECRET_HASH="<sha256-hex-of-admin-password>"

# --- App Environment (set to "production" in prod, omit in dev) ---
# APP_ENV=production
